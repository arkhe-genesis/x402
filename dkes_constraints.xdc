
# =============================================================================
# XDC Constraints — DKES_RTL FPGA
# Seal: FPGA-SYNTHESIS-DKES-2026-06-02
# =============================================================================

# 1. Clock definitions
# System clock: 300 MHz (3.33ns period)
create_clock -name sys_clk -period 3.333 [get_ports clk]

# NTT engine clock: 600 MHz (1.667ns period) — generated by PLL
create_clock -name ntt_clk -period 1.667 [get_pins ntt_pll/clk_out]

# AXI clock: 250 MHz (4ns period)
create_clock -name axi_clk -period 4.000 [get_ports axi_aclk]

# 2. Clock groups
set_clock_groups -asynchronous -group [get_clocks sys_clk] -group [get_clocks ntt_clk]
set_clock_groups -asynchronous -group [get_clocks sys_clk] -group [get_clocks axi_clk]

# 3. I/O constraints
# PCIe Gen3 x16 — 8 GT/s
set_property LOC GTYE4_CHANNEL_X0Y0 [get_ports {pcie_rxp[0]}]
set_property LOC GTYE4_CHANNEL_X0Y1 [get_ports {pcie_rxp[1]}]
# ... (16 lanes)

# HBM2 interface — 900 MHz
set_property LOC HBM_X0Y0 [get_ports hbm_*]

# 4. Timing constraints
# Setup time: 2.5ns (75% of period)
set_input_delay -clock sys_clk -max 2.5 [get_ports query_in[*]]
set_input_delay -clock sys_clk -min 0.5 [get_ports query_in[*]]

# Output delay: 2.0ns
set_output_delay -clock sys_clk -max 2.0 [get_ports score_out]
set_output_delay -clock sys_clk -min 0.3 [get_ports score_out]

# 5. False paths
# Reset synchronizer
set_false_path -from [get_ports rst_n] -to [get_cells sync_reset*]

# Axiarchy flags — não críticos para timing
set_false_path -to [get_ports state_out[*]]

# 6. Multi-cycle paths
# NTT butterfly — 2 ciclos para multiplicação modular
set_multicycle_path -setup 2 -from [get_cells ntt_butterfly*] -to [get_cells ntt_butterfly*]
set_multicycle_path -hold 1 -from [get_cells ntt_butterfly*] -to [get_cells ntt_butterfly*]

# 7. Placement constraints
# NTT engine — colocar próximo ao HBM para baixa latência
create_pblock pblock_ntt
add_cells_to_pblock pblock_ntt [get_cells ntt_engine*]
resize_pblock pblock_ntt -add {SLICE_X0Y0:SLICE_X100Y100}

# Dual solver — DSP slices para MAC operations
create_pblock pblock_solver
add_cells_to_pblock pblock_solver [get_cells dual_solver*]
resize_pblock pblock_solver -add {DSP48E2_X0Y0:DSP48E2_X50Y50}

# 8. Power constraints
# Enclave TEE — isolamento elétrico
set_property ISOLATED "TRUE" [get_cells enclave_*]
set_property POWER_GROUP "ENCLAVE" [get_cells enclave_*]

# 9. Bitstream settings
set_property BITSTREAM.CONFIG.SPI_BUSWIDTH 4 [current_design]
set_property BITSTREAM.CONFIG.CONFIGRATE 85.0 [current_design]
set_property BITSTREAM.GENERAL.COMPRESS TRUE [current_design]
set_property BITSTREAM.CONFIG.USERID 32'hDKES2026 [current_design]
